# data-fire 后端环境变量示例。复制为 .env 并按实际填写。
# DATABASE_URL 由 Prisma 使用，格式：mysql://用户:密码@主机:端口/库名
DATABASE_URL=mysql://root:root@localhost:3306/datafire
# Redis 连接串
REDIS_URL=redis://localhost:6379/0
# FastAPI 监听端口
PORT=8000
# 允许的前端来源。本地可用 *；生产建议写具体域名。多个域名用英文逗号分隔，后端会逐个允许。
# 例：CORS_ORIGIN=https://dashboard.example.com,https://www.example.com,http://localhost:5173
CORS_ORIGIN=*
# 项目指纹锁过期秒数，防并发重复分配 projectId
PROJECT_LOCK_TTL=60
